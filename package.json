{
  "name": "circle-kikaku-tools",
  "private": true,
  "version": "7.0.0-calm-workspace",
  "scripts": {
    "test": "node tests/run-static-tests.js",
    "lint:css": "stylelint \"assets/css/**/*.css\"",
    "test:ui": "playwright test tests/basic-ui.spec.js",
    "test:visual": "playwright test tests/visual-regression.spec.js",
    "test:refinement": "playwright test tests/refinement-audit.spec.js",
    "test:guard": "stylelint \"assets/css/**/*.css\" && node tests/run-static-tests.js && playwright test tests/basic-ui.spec.js && playwright test tests/visual-regression.spec.js",
    "test:visual:update": "playwright test tests/visual-regression.spec.js --update-snapshots"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "6.4.0",
    "@playwright/test": "^1.61.0",
    "bootstrap": "5.3.0",
    "sortablejs": "1.15.0",
    "stylelint": "^17.13.0"
  }
}
